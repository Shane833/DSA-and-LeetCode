HuffmanTree *HuffmanTree_create(const unsigned char *msg){
    PQueue *q = Huffman_createMinHeapFromString(msg);
    check(q != NULL, "Failed to create min heap from string!");

    size_t n = PQueue_Size(q);
    // for n items we need n - 1 merge operations 
    for(int i = 0;i < n - 1;i++){
        HuffmanNode *node = createHuffmanNode('\0', 0);
        check(node != NULL, "Failed to create HuffmanNode!");

        HuffmanNode *a = (HuffmanNode *)PQueue_Dequeue(q);
        HuffmanNode *b = (HuffmanNode *)PQueue_Dequeue(q);

        node->left = a;
        node->right = b;

        node->freq = a->freq + b->freq;

        PQueue_Enqueue(q, node); // Merging two smallest nodes at a time
                                 // and inserting them back into the min heap
    }
    
    HuffmanTree *tree (HuffmanTree *)malloc(sizeof(HuffmanTree));
    check(tree != NULL, "Failed to create the Huffman Tree");

    tree->root = (HuffmanNode *)PQueue_Dequeue(q); // in the end only the root remains
    PQueue_ClearDestroy(q);
    q = NULL;

    Hashmap *map = Hashmap_createStatic(NULL, NULL, n);
    check(map != NULL, "Failed to create Hashmap!");
    
    
error:
    return NULL;
}
