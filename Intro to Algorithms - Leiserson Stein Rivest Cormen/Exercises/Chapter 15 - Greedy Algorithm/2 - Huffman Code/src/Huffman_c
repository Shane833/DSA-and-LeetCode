#include <Huffman.h>

static HuffmanNode *HuffmanNode_create(char c, size_t freq){
    HuffmanNode *node = (HuffmanNode*)malloc(sizeof(HuffmanNode));
    check(node != NULL, "Failed to create HuffmanNode!");

    node->c = c;
    node->freq = freq;
    node->left = NULL;
    node->right = NULL;

    return node;
error:
    return NULL;
}

// Compare function for PQueue
static int keyCompare(const HuffmanNode *a, const HuffmanNode *b){
    return a->freq - b->freq;
}

static PQueue *Huffman_createMinHeapFromString(const unsigned char *msg){
    int map[UCHAR_MAX] = { 0 };
    for(int i = 0;i < strlen(msg);i++){
        map[msg[i]]++; // counter
    } 
    // Getting the count of unique chars
    size_t count = 0;
    for(int i = 0;i < UCHAR_MAX;i++){
        if(map[i] != 0){
            count++;
        }
    }
    // Create a new PQueue
    PQueue *q = PQueue_Create(count, (PQueue_Compare)keyCompare);
    check(q != NULL, "Failed to create PQueue!"); 
    
    // Creating a min heap from these nodes
    for(int i = 0;i < UCHAR_MAX;i++){
        if(map[i] != 0){
            HuffmanNode *node = createHuffmanNode(i, map[i]);
            check(node != NULL, "Failed to create HuffmanNode!");
            
            PQueue_Enqueue(q, node);
        }
    }

    return q;
error:
    return NULL;
}

